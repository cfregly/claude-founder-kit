# Copy to .env (git-ignored). The core runs offline with none of these set.

# Capture backend: local (default), posthog, statsig, amplitude.
ACTIVATION_BACKEND=local
# Telemetry is opt-out. Set to off, false, no, or 0 to make emit a no-op.
ACTIVATION_TELEMETRY=on
# Where the local backend writes the JSONL event log.
ACTIVATION_EVENT_LOG=events.jsonl

# PostHog. Self-host by changing the host.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Statsig.
STATSIG_API_KEY=

# Amplitude.
AMPLITUDE_API_KEY=
AMPLITUDE_HOST=https://api2.amplitude.com

# Live Claude layers (enrich, decide, draft, render) and both live harnesses.
# Leave empty in the example; set it in .env or export it before running make demo.
# Deterministic subcommands and tests still run without a key.
ANTHROPIC_API_KEY=
# Test harness only: set to 1 when you need to prove a missing-key path ignores local .env.
PYTHON_DOTENV_DISABLED=
