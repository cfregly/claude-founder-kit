# Copy to .env (git-ignored) for the optional --judge flag. The linter, the
# tests, and the score run offline with no key, so this is only for the judge.

# --judge has claude-opus-4-8 read for semantic slop the rules cannot catch. It
# is advisory and never changes the score. Get a key at
# https://console.anthropic.com/ and `pip install anthropic`.
ANTHROPIC_API_KEY=sk-ant-...
