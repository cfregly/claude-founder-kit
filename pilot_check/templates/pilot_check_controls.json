{
  "permissions": {
    "always": [
      "rank_customer_risk",
      "read_customer_evidence",
      "score_programmatic_tool_calling_receipt"
    ],
    "ask": [
      "create_sales_task",
      "send_customer_update",
      "open_support_ticket"
    ],
    "never": [
      "delete_customer_data",
      "charge_customer",
      "grant_credits",
      "post_public_message"
    ]
  },
  "logs": {
    "required_fields": [
      "log_event_id",
      "run_id",
      "case_id",
      "actor",
      "intent",
      "permission",
      "pilot_check",
      "access_level",
      "rollout_decision",
      "fallback",
      "receipt_source",
      "monitoring",
      "trace_present",
      "log_hash"
    ],
    "retention": "keep audit logs long enough to debug pilot decisions, billing, and customer disputes",
    "redaction": "log handles and decisions, not API keys, raw secrets, or unnecessary customer payloads"
  },
  "monitoring": {
    "defaults": {
      "eval_pass_rate": 1.0,
      "latency_p95_ms": 1200,
      "fallback_rate": 0.0,
      "policy_denial_rate": 0.0,
      "cost_per_successful_task_usd": 0.08
    },
    "signals": [
      "eval_pass_rate",
      "latency_p95_ms",
      "fallback_rate",
      "policy_denial_rate",
      "cost_per_successful_task_usd",
      "tool_error_rate",
      "trace_missing_rate",
      "receipt_missing_rate"
    ]
  }
}
